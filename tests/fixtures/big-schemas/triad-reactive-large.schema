[SignalIn
 NexusIn
 SemaIn
 Admin
 Heartbeat]
[SignalOut
 NexusOut
 SemaOut
 AdminOut
 Event
 Rejected]
{
  SignalIn SignalRequest
  NexusIn NexusRequest
  SemaIn SemaRequest
  Admin AdminRequest
  SignalOut SignalReply
  NexusOut NexusReply
  SemaOut SemaReply
  AdminOut AdminReply
  Event RuntimeEvent
  Rejected RejectedReply
  CommitSequence Integer
  DatabaseDigest Integer
  ActorIdentifier String
  SocketPath String
  SignalRequest [(RecordIntent) (ObserveIntent) (SubscribeIntent)]
  SignalReply [(RecordAccepted) (ObservationReturned) (SubscriptionStarted)]
  NexusRequest [(PushSignal) (PushSemaResult) ResolveMail ExpireMail]
  NexusReply [(PushedToSema) (MailResolved) MailExpired]
  SemaRequest [(WriteEntry) (ReadEntries) (OpenSubscription) (CloseSubscription)]
  SemaReply [(EntryWritten) (EntriesRead) (SubscriptionOpened) (SubscriptionClosed)]
  AdminRequest [Drain Pause Resume (Snapshot)]
  AdminReply [Drained Paused Resumed (SnapshotReady)]
  RuntimeEvent [(MailSent) (MessageAccepted) (MessageCommitted) (MessageFailed)]
  RejectedReply { RejectionReason }
  RejectionReason [Malformed Unauthorized Conflict Unsupported StaleVersion InternalError]
  RecordIntent { ActorIdentifier Entry }
  ObserveIntent { Query }
  SubscribeIntent { Query }
  RecordAccepted { RecordIdentifier CommitSequence }
  ObservationReturned { RecordSet }
  SubscriptionStarted { SubscriptionToken }
  PushSignal { SignalRequest }
  PushSemaResult { SemaReply }
  PushedToSema { SemaRequest }
  MailResolved { SignalReply }
  WriteEntry { Entry }
  ReadEntries { Query }
  OpenSubscription { Query }
  CloseSubscription { SubscriptionToken }
  EntryWritten { RecordIdentifier CommitSequence DatabaseDigest }
  EntriesRead { RecordSet DatabaseDigest }
  SubscriptionOpened { SubscriptionToken CommitSequence }
  SubscriptionClosed { SubscriptionToken CommitSequence }
  Snapshot { SocketPath }
  SnapshotReady { SocketPath DatabaseDigest }
  MailSent { SignalRequest }
  MessageAccepted { SignalRequest }
  MessageCommitted { CommitSequence }
  MessageFailed { RejectionReason }
  Entry { Topics Kind Description Magnitude ActorIdentifier }
  Topic String
  Topics (Vector Topic)
  Description String
  Kind [Decision Principle Correction Clarification Constraint Observation Question]
  Magnitude [Minimum VeryLow Low Medium High VeryHigh Maximum]
  Kinds (Vector Kind)
  Limit (Optional Integer)
  Query { Topics Kinds Limit }
  RecordIdentifier Integer
  SubscriptionToken Integer
  Records (Vector Entry)
  ByTopic (Map Topic RecordIdentifier)
  RecordSet { Records ByTopic }
}
